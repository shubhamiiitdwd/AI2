# ── AI Kosh Team 1 AutoML Configuration ─────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ── Local API port (single place to change for backend + UI proxy + WebSockets) ──
BACKEND_PORT=8099

# ── Hugging Face (open-source AI assistant) ──
# Get a free token from https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=your-huggingface-token-here
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# ── H2O AutoML Settings ──
H2O_MAX_MODELS=20
H2O_MAX_RUNTIME_SECS=300
H2O_NFOLDS=5
H2O_SEED=42

# Optional: delete SQLite training_runs older than this date (YYYY-MM-DD) once when the API starts.
# Example: TRAINING_HISTORY_PRUNE_BEFORE=2026-04-15
# TRAINING_HISTORY_PRUNE_BEFORE=

# ── Azure OpenAI (uncomment when access granted) ──
# AZURE_OPENAI_API_KEY=your-api-key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-02-01

# ── Azure Blob Storage (uncomment when access granted) ──
# Use one container; all AutoML blobs go under a virtual folder (prefix) inside it.
#
# Option A — full connection string (from Azure Portal → Storage account → Access keys):
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
#
# Option B — account name + key (same as a small upload script; no need to paste the full string):
# AZURE_STORAGE_ACCOUNT_NAME=aeetlgenaikoshstg01
# AZURE_STORAGE_ACCOUNT_KEY=your-key-from-portal
# Optional if not using public Azure: AZURE_STORAGE_ENDPOINT_SUFFIX=core.windows.net
#
# AZURE_BLOB_CONTAINER_NAME=aikosh-v2
# AZURE_STORAGE_AUTOML_PREFIX=automl
#
# Optional: fail fast at startup if Azure blob is required (set when debugging laptops):
# AZURE_STORAGE_REQUIRE_AZURE=true
#
# Note: variables like AZURE_STORAGE_CONTAINER_DATASETS are not used — one container + prefix only.
#
# Blob layout (prefix defaults to automl):
#   {prefix}/datasets/{dataset_id}/{file}
#   {prefix}/models/{run_id}/{file}
#   {prefix}/results/training/{run_id}/result.json
#   {prefix}/results/clustering/{run_id}/result.json
